{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "nb-meta",
  "type": "object",
  "required": ["protocol", "series", "slug", "template", "title", "mode", "date", "sources", "dek", "harness", "model"],
  "properties": {
    "protocol": {"type": "string", "pattern": "^1\\."},
    "series": {"type": "string", "pattern": "^[a-z0-9-]{1,32}$"},
    "slug": {"type": "string", "pattern": "^[a-z0-9-]{1,64}$"},
    "template": {"type": "string", "description": "a template id from the merged registry (shipped or press-defined)"},
    "title": {"type": "string", "minLength": 1, "maxLength": 200},
    "mode": {"enum": ["collection", "sequence", "rolling"]},
    "order": {"type": ["integer", "null"], "minimum": 1},
    "date": {"type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$"},
    "tags": {"type": "array", "items": {"type": "string", "pattern": "^[a-z0-9-]{1,32}$"}},
    "sources": {"type": "integer", "minimum": 1},
    "words": {"type": "integer", "minimum": 1},
    "reading_minutes": {"type": "integer", "minimum": 1},
    "dek": {"type": "string", "minLength": 1, "maxLength": 300},
    "harness": {"type": "string"},
    "model": {"type": "string"}
  }
}
